// Polkit rules for PWA service control from web app
// Install to: /etc/polkit-1/rules.d/10-pwa-services.rules
//
// This allows the web app (running as the user) to control PWA services
// via systemctl --user commands without requiring sudo.

polkit.addRule(function(action, subject) {
  // Only allow actions on PWA services
  if (action.id.indexOf("org.freedesktop.systemd1.manage-unit-files") !== -1 ||
      action.id.indexOf("org.freedesktop.systemd1.manage-units") !== -1) {

    // Check if the action is for a PWA service
    var serviceName = action.lookup("unit");
    if (serviceName && serviceName.indexOf("pwa-") === 0) {
      // Allow if user is in the same session
      if (subject.isInGroup("users")) {
        return polkit.Result.YES;
      }
    }
  }

  // Allow systemctl --user commands for PWA services
  if (action.id === "org.freedesktop.systemd1.manage-user-units") {
    var unit = action.lookup("unit");
    if (unit && unit.indexOf("pwa-") === 0) {
      // Allow for same user
      if (subject.user === polkit.spawn(["whoami"]).stdout.trim()) {
        return polkit.Result.YES;
      }
    }
  }

  return polkit.Result.NOT_HANDLED;
});
