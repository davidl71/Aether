# Ansible-lint configuration (https://ansible.readthedocs.io/projects/lint/)
# Run: ansible-lint ansible/  or  just ansible-lint
profile: basic
# Lint playbooks and roles under ansible/
exclude_paths:
  - .git/
  - .github/
mock_modules:
  - community.general.homebrew
  - community.general.homebrew_tap
skip_list:
  - command-instead-of-module
  - jinja
  - key-order
  - name
  - var-naming
  - yaml
