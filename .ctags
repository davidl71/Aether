--langmap=C++:+.h
--langmap=Rust:+.rs
--langmap=Python:+.py

--languages=+C++,Rust,Python

--exclude=.git
--exclude=build
--exclude=target
--exclude=node_modules
--exclude=third_party
--exclude=*_generated*
--exclude=*.pb.cc
--exclude=*.pb.h
--exclude=*.g.dart

--recurse=yes

--fields=+KS

--tag-relative=yes
