{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/rules/exarp-go.md",
    ".opencode/rules/lint-after-generation.md",
    ".opencode/rules/regression-sanity.md",
    ".opencode/rules/derive-builder-pattern.md",
    ".opencode/rules/shared-types-pattern.md"
  ],
  "mcp": {
    "exarp-go": {
      "type": "local",
      "command": ["/Users/davidl/Projects/mcp/exarp-go/bin/exarp-go"],
      "enabled": true,
      "environment": {
        "PROJECT_ROOT": "/Users/davidl/Projects/Trading/ib_box_spread_full_universal",
        "EXARP_MIGRATIONS_DIR": "/Users/davidl/Projects/mcp/exarp-go/migrations",
        "EXARP_WATCH": "0",
        "NO_COLOR": "1"
      }
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/Users/davidl/Projects/Trading/ib_box_spread_full_universal", "/Users/davidl/Projects/Trading/Jts", "/Users/davidl/Projects/Trading/ntws", "/Users/davidl/Projects/Trading/tws-api", "/Users/davidl/Projects/Trading/yatws"],
      "enabled": true
    },
    "sequential_thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "tractatus_thinking": {
      "type": "local",
      "command": ["npx", "-y", "tractatus_thinking"],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": ["uvx", "mcp-server-fetch"],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true
    },
    "git": {
      "type": "local",
      "command": ["uvx", "mcp-server-git", "--repository", "/Users/davidl/Projects/Trading/ib_box_spread_full_universal"],
      "enabled": true
    },
    "ctags-lsp": {
      "type": "local",
      "command": ["ctags-lsp"],
      "enabled": false
    },
    "lsp-mcp": {
      "type": "local",
      "command": ["lsp-mcp", "--project", "/Users/davidl/Projects/Trading/ib_box_spread_full_universal"],
      "enabled": false
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@teolin/mcp-github"],
      "enabled": true
    },
    "rust-docs": {
      "type": "local",
      "command": ["/Users/davidl/.cargo/bin/rust-docs-mcp"],
      "enabled": true,
      "environment": {
        "RUST_DOCS_MCP_CACHE_DIR": "/Users/davidl/.rust-docs-mcp/cache"
      }
    }
  }
}
