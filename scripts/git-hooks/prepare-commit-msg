#!/bin/sh
# Add Co-authored-by trailer from git config so you don't have to type it each time.
# Setup (from repo root):
#   1. git config core.hooksPath scripts/git-hooks
#   2. git config ib_box_spread.coauthor "Co Author Name <email@example.com>"
# Or copy this file to .git/hooks/prepare-commit-msg and set the config.
#
# Skip for merge/squash and when Co-authored-by is already in the message.
# Reads ib_box_spread.coauthor; falls back to exarp-go.coauthor for compatibility.
set -e
msgfile="$1"
source="${2:-}"
coauthor=$(git config --get ib_box_spread.coauthor 2>/dev/null) ||
  git config --get exarp-go.coauthor 2>/dev/null || true
[ -n "$coauthor" ] || exit 0
[ -n "$msgfile" ] && [ -f "$msgfile" ] || exit 0
case "$source" in merge | squash) exit 0 ;; esac
grep -q '^Co-authored-by:' "$msgfile" 2>/dev/null && exit 0
printf '\nCo-authored-by: %s\n' "$coauthor" >>"$msgfile"
