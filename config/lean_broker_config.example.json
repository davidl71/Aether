{
  "comment": "LEAN Broker Configuration Examples",
  "description": "Example configurations for IBKR and Alpaca brokerages in LEAN",

  "interactive_brokers_paper": {
    "brokerage-type": "InteractiveBrokers",
    "interactive-brokers": {
      "host": "127.0.0.1",
      "port": 7497,
      "account": "DU123456",
      "username": "",
      "password": "",
      "trading-mode": "paper"
    }
  },

  "interactive_brokers_live": {
    "brokerage-type": "InteractiveBrokers",
    "interactive-brokers": {
      "host": "127.0.0.1",
      "port": 7496,
      "account": "U123456",
      "username": "",
      "password": "",
      "trading-mode": "live"
    }
  },

  "alpaca_paper": {
    "brokerage-type": "Alpaca",
    "alpaca": {
      "key-id": "PK...",
      "secret-key": "YOUR_SECRET_KEY",
      "base-url": "https://paper-api.alpaca.markets",
      "trading-mode": "paper"
    }
  },

  "alpaca_live": {
    "brokerage-type": "Alpaca",
    "alpaca": {
      "key-id": "AK...",
      "secret-key": "YOUR_SECRET_KEY",
      "base-url": "https://api.alpaca.markets",
      "trading-mode": "live"
    }
  },

  "notes": {
    "ibkr": {
      "ports": {
        "tws_paper": 7497,
        "tws_live": 7496,
        "gateway_paper": 4002,
        "gateway_live": 4001
      },
      "account_format": {
        "paper": "DU123456",
        "live": "U123456"
      },
      "requirements": [
        "TWS or IB Gateway must be running",
        "API must be enabled in TWS Settings > API > Settings",
        "Enable 'ActiveX and Socket Clients'",
        "Trust IP address (127.0.0.1 for local)"
      ]
    },
    "alpaca": {
      "api_keys": {
        "paper": "Start with PK...",
        "live": "Start with AK..."
      },
      "endpoints": {
        "paper": "https://paper-api.alpaca.markets",
        "live": "https://api.alpaca.markets"
      },
      "requirements": [
        "Alpaca account created",
        "API keys generated",
        "Account permissions verified",
        "Options trading enabled (if needed)"
      ]
    }
  }
}
