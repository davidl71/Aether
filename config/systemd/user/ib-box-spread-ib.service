[Unit]
Description=IB Box Spread - IB backend service
After=network.target

[Service]
Type=simple
EnvironmentFile=%h/.config/systemd/user/ib-box-spread.env
WorkingDirectory=%h/.config/systemd/user
ExecStart=/bin/bash -c 'cd "${PROJECT_ROOT}/python" && exec python -m uvicorn integration.ib_service:app --host 0.0.0.0 --port 8002'
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
