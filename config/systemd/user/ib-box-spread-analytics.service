[Unit]
Description=IB Box Spread - Analytics API (calculations + risk-free rate)
After=network.target

[Service]
Type=simple
EnvironmentFile=%h/.config/systemd/user/ib-box-spread.env
WorkingDirectory=%h/.config/systemd/user
ExecStart=/bin/bash -c 'cd "${PROJECT_ROOT}/python" && exec python -m uvicorn services.analytics_api:app --host 0.0.0.0 --port 8007'
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
