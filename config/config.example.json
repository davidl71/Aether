{
  // ============================================================================
  // TWS Connection Configuration
  // ============================================================================
  "tws": {
    "host": "127.0.0.1", // TWS/Gateway hostname (localhost)
    "port": 7497, // Port: 7497 = Paper Trading (safe, REAL DATA), 7496 = Live Trading (REAL MONEY!)
    "client_id": 1, // Unique client ID (1-32), must be unique per connection
    "connection_timeout_ms": 60000, // Connection timeout in milliseconds (60 seconds - timeout for waiting for nextValidId after socket connection)
    "auto_reconnect": true, // Automatically reconnect on disconnection
    "reconnect_delay_ms": 3000, // Delay before reconnection attempt (milliseconds)
    "log_raw_messages": false, // Log raw API messages/data for debugging (verbose - use with "trace" log_level)
    "use_mock": false, // Use mock TWS client (no live IB connection, set to true for simulated data)
    "nats_url": "nats://127.0.0.1:4222" // Optional NATS publish URL when the native client is built with NATS
  },

  // ============================================================================
  // Strategy Configuration
  // ============================================================================
  "strategy": {
    // Symbols to monitor for box spread opportunities
    // Default to European-style symbols: SPX, XSP, NDX (European exercise style)
    // American-style symbols (SPY, QQQ, IWM) are hidden by default
    "symbols": ["SPX", "XSP", "NDX"],

    // Financing rate thresholds (minimum requirements to execute a trade)
    "min_implied_rate_advantage_bps": 50, // Minimum rate advantage over benchmark in basis points (50 bps = 0.5%)
    "min_implied_rate_percent": 4.0, // Minimum implied interest rate to consider (4.0 = 4.0% APR)
    "benchmark_rate_source": "SOFR", // Benchmark for rate comparison: "SOFR", "TREASURY", or "MARGIN_LOAN"
    // Legacy parameters (deprecated, kept for backward compatibility)
    "min_arbitrage_profit": 0.1, // DEPRECATED: Use min_implied_rate_advantage_bps instead
    "min_roi_percent": 0.5, // DEPRECATED: Use min_implied_rate_percent instead

    // Position sizing
    "max_position_size": 10000.0, // Maximum capital per trade in dollars

    // Expiration filters
    "min_days_to_expiry": 30, // Minimum days until expiration
    "max_days_to_expiry": 90, // Maximum days until expiration

    // Liquidity filters (ensure options are tradeable)
    "max_bid_ask_spread": 0.1, // Maximum bid/ask spread in dollars
    "min_volume": 100, // Minimum daily volume
    "min_open_interest": 500 // Minimum open interest
  },

  // ============================================================================
  // Risk Management Configuration
  // ============================================================================
  "risk": {
    // Portfolio-level limits
    "max_total_exposure": 50000.0, // Maximum total capital deployed across all positions
    "max_positions": 10, // Maximum number of concurrent positions

    // Position-level limits
    "max_loss_per_position": 1000.0, // Maximum loss per position before stop-loss

    // Daily limits
    "max_daily_loss": 2000.0, // Stop trading if daily loss exceeds this amount

    // Position sizing
    "position_size_percent": 0.1, // Position size as percentage of account (0.1 = 10%)

    // Stop-loss configuration
    "enable_stop_loss": true, // Enable automatic stop-loss
    "stop_loss_percent": 0.2 // Stop-loss threshold (0.2 = 20% loss)
  },

  // ============================================================================
  // Logging Configuration
  // ============================================================================
  "logging": {
    "log_file": "logs/ib_box_spread.log", // Log file path
    "log_level": "info", // Log level: trace, debug, info, warn, error, critical
    "max_file_size_mb": 10, // Maximum log file size before rotation
    "max_files": 5, // Number of rotated log files to keep
    "log_to_console": true // Also log to console (stdout)
  },

  // ============================================================================
  // Application Settings
  // ============================================================================
  "dry_run": true, // Dry-run mode: simulate trades without executing (SAFE)
  "loop_delay_ms": 1000, // Delay between strategy evaluation loops (milliseconds)
  "continue_on_error": false, // Continue running after errors (false = exit on error)

  // ============================================================================
  // Broker Selection (Primary integration defaults to IB for real data)
  // ============================================================================
  "broker": {
    "primary": "IB", // Options: "IB", "ALPACA" (IB is the active default)
    "priorities": ["ib", "alpaca", "fibi", "meitav", "ibi", "discount", "mock"]
  },

  // ============================================================================
  // Portfolio / reporting currency (for P&L, exposure, hedging suggestions)
  // ============================================================================
  "portfolio": {
    "primary_currency": "USD" // Reporting currency: "USD", "ILS", etc. Used for conversion and TASE/hedge suggestions. Optional; default USD.
  },

  // ============================================================================
  // Alpaca Integration (Optional)
  // ============================================================================
  "alpaca": {
    // See https://docs.alpaca.markets/
    // Use separate credentials for paper vs live accounts.
    // Trading endpoints differ by environment; market-data endpoint is separate.
    //
    // Environment variables (set via CLI cred commands or directly):
    //   APCA_API_KEY_ID       - API key ID (shared for paper/live)
    //   APCA_API_SECRET_KEY   - API secret (shared for paper/live)
    //   APCA_API_BASE_URL     - Determines paper vs live:
    //                           https://paper-api.alpaca.markets (paper)
    //                           https://api.alpaca.markets (live)
    "data_client_config": {
      "api_key_id": "${APCA_API_KEY_ID}",
      "api_secret_key": "${APCA_API_SECRET_KEY}",
      "base_url": "https://paper-api.alpaca.markets",
      "data_base_url": "https://data.alpaca.markets",
      "paper": true
    },
    "exec_client_config": {
      "api_key_id": "${APCA_API_KEY_ID}",
      "api_secret_key": "${APCA_API_SECRET_KEY}",
      "base_url": "https://paper-api.alpaca.markets",
      "paper": true
    },
    "live_example": {
      "api_key_id": "${APCA_API_KEY_ID}",
      "api_secret_key": "${APCA_API_SECRET_KEY}",
      "base_url": "https://api.alpaca.markets",
      "data_base_url": "https://data.alpaca.markets",
      "paper": false
    }
  },

  // ============================================================================
  // Massive.com Integration (Optional)
  // ============================================================================
  "massive": {
    "enabled": false, // Enable Massive.com integration
    "api_key": "${MASSIVE_API_KEY}", // API key from Massive.com dashboard
    "base_url": "https://api.massive.com", // Base URL for REST API

    // Feature flags
    "use_for_historical_data": true, // Use for historical trade/quote data
    "use_for_realtime_quotes": true, // Use for real-time quote cross-validation
    "use_for_dividend_data": true, // Use for dividend tracking
    "use_for_fundamental_data": true, // Use for fundamental quality filtering

    // WebSocket configuration
    "websocket_enabled": false, // Enable WebSocket for real-time quotes
    "websocket_url": "wss://api.massive.com/ws", // WebSocket URL

    // Fundamental filtering
    "min_market_cap": 1000000000, // Minimum market cap ($1B)
    "max_pe_ratio": 50.0, // Maximum P/E ratio
    "avoid_penny_stocks": true, // Filter out penny stocks

    // Risk management
    "dividend_blackout_days": 2, // Avoid trades N days before dividend ex-date

    // Performance settings
    "cache_duration_seconds": 300, // Cache duration (5 minutes)
    "rate_limit_per_second": 10 // Max requests per second
  },

  // ============================================================================
  // TUI Configuration (Python Textual Interface)
  // ============================================================================
  "tui": {
    "provider_type": "rest", // "mock", "rest", "file", "ibkr_rest" (changed from mock to rest for real data)
    "rest_endpoint": "http://localhost:8080/api/v1/snapshot", // Rust backend shared snapshot endpoint
    "update_interval_ms": 1000,
    "refresh_rate_ms": 500,
    "rest_timeout_ms": 15000,
    "rest_verify_ssl": false,
    "ibkr_rest": {
      "base_url": "https://localhost:5001/v1/portal",
      "account_id": "",
      "verify_ssl": false,
      "timeout_ms": 5000
    },
    "display": {
      "show_colors": true,
      "show_footer": true
    }
  },

  // ============================================================================
  // Service Port Configuration
  // ============================================================================
  // Port assignments for PWA services to prevent conflicts
  // Environment variables can override: WEB_PORT, ALPACA_PORT, IB_PORT, etc.
  "services": {
    "web": {
      "port": 5173 // Vite dev server (frontend)
    },
    "discount_bank": {
      "port": 8003 // Discount Bank service
    },
    "nats": {
      "port": 4222, // NATS client connection port
      "http_port": 8222, // NATS HTTP monitoring port
      "websocket_port": 8081 // NATS WebSocket port (changed from 8080 to avoid conflict with Rust backend)
    },
    "rust_backend": {
      "rest_port": 8080, // Rust backend REST API port
      "grpc_port": 50051 // Rust backend gRPC API port
    },
    "ib_gateway": {
      "port": 5001 // IB Client Portal Gateway HTTPS port
    }
  },

  // ============================================================================
  // Tastytrade Integration (RETIRED from active runtime - kept for future reintroduction)
  // ============================================================================
  // "tastytrade": {
  //   // See https://tastytrade.com/api/
  //   // NOTE: Tastytrade is retired from active runtime surface as of March 2026.
  //   // Uncomment and configure if you want to re-enable in the future.
  //   "oauth": {
  //     "client_secret": "${TASTYTRADE_CLIENT_SECRET}",
  //     "refresh_token": "${TASTYTRADE_REFRESH_TOKEN}"
  //   },
  //   "username": "${TASTYTRADE_USERNAME}",
  //   "password": "${TASTYTRADE_PASSWORD}",
  //   "base_url": "https://api.tastytrade.com",
  //   "sandbox_base_url": "https://api.cert.tastyworks.com",
  //   "sandbox_websocket_url": "wss://streamer.cert.tastyworks.com",
  //   "sandbox": false
  // }
}
