      },
      {
        "type": "webhook",
        "url": "https://hooks.example.com/ib-alerts",
        "events": ["reauth_start", "reauth_success", "strategy_start"]
      },
      {
        "type": "telegram",
        "bot_token": "",
        "chat_id": "",
        "events": ["reauth_failure", "strategy_paused"]
      }
    ]
  },
  "data_providers": {
    "primary": "ib",
    "fallbacks": ["orats"]
