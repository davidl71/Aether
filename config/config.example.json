{
  "tws": {
    "host": "127.0.0.1",
    "port": 7497,
    "client_id": 1,
    "connection_timeout_ms": 5000,
    "auto_reconnect": true,
    "reconnect_delay_ms": 3000
  },
  "strategy": {
    "symbols": ["SPY", "QQQ", "IWM"],
    "min_arbitrage_profit": 0.10,
