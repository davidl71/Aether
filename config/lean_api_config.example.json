{
  "lean_api": {
    "enabled": false,
    "base_url": "http://localhost:8000",
    "api_key": null,
    "websocket": {
      "enabled": true,
      "reconnect": true,
      "reconnect_interval_ms": 3000,
      "max_reconnect_attempts": 10
    }
  },
  "rust_backend": {
    "enabled": true,
    "base_url": "http://localhost:8080",
