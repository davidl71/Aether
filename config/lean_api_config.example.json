  },
  "pwa": {
    "use_lean_api": false,
    "poll_interval_ms": 2000,
    "websocket_enabled": true
  },
  "tui": {
    "use_lean_api": false,
    "endpoint": "http://localhost:8000/api/v1/snapshot",
    "poll_interval_ms": 2000
  }
}
