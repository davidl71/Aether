{
  "recommendations": [
    // C++ Development
    "ms-vscode.cpptools",
    "ms-vscode.cmake-tools",

    // Python Development
    "ms-python.python",
    "ms-python.vscode-pylance",
    "ms-python.black-formatter",

    // Rust Development (for agents/backend)
    "rust-lang.rust-analyzer",

    // TypeScript/JavaScript (for web/)
    "dbaeumer.vscode-eslint",

    // General Development
    "editorconfig.editorconfig",
    "redhat.vscode-yaml",

    // Git
    "eamodio.gitlens",

    // Markdown
    "yzhang.markdown-all-in-one",
    "davidanson.vscode-markdownlint",

    // Shell Scripts
    "timonwong.shellcheck",

    // Code Quality & Security
    "streetsidesoftware.code-spell-checker",
    "usernamehw.errorlens",

    // AI & Prompt Enhancement
    "prompttower.prompttower",

    // Swift (for ios/ and desktop/)
    "sswg.swift-lang",

    // MCP Integration
    "yutengjing.vscode-mcp"
  ],
  "unwantedRecommendations": [
    // Redundant - cpptools-extension-pack includes cpptools which is already recommended
    "ms-vscode.cpptools-extension-pack",

    // Not needed - no Docker/Kubernetes configuration in this project
    "ms-azuretools.vscode-containers",
    "ms-kubernetes-tools.vscode-kubernetes-tools",
    "ms-vscode-remote.remote-containers",

    // Not used - no Go code in this project
    "golang.go",

    // Optional - Prettier may conflict with ESLint formatting rules configured in web/eslint.config.js
    // Keep if you prefer Prettier's formatting style, otherwise ESLint handles formatting
    "esbenp.prettier-vscode",

    // Trunk CLI is used via scripts/run_linters.sh, not as VS Code formatter extension
    // Explicit formatters are configured in settings.json to prevent auto-detection
    "trunk.io"
  ]
}
