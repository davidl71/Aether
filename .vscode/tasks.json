            "tell application \"iTerm2\"\n  tell current window\n    create tab with default profile\n    tell current session of current tab\n      write text \"cd '${workspaceFolder}' && ./scripts/build_universal.sh\"\n    end tell\n  end tell\nend tell"
          ]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Run Linters",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/run_linters.sh",
      "args": [],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Linters (iTerm2)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/run_linters.sh",
      "args": [],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "options": {
        "shell": {
          "executable": "/usr/bin/osascript",
          "args": [
            "-e",
            "tell application \"iTerm2\"\n  tell current window\n    create tab with default profile\n    tell current session of current tab\n      write text \"cd '${workspaceFolder}' && ./scripts/run_linters.sh\"\n    end tell\n  end tell\nend tell"
          ]
        }
      },
      "problemMatcher": []
