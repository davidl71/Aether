      "type": "shell",
      "command": "${workspaceFolder}/scripts/build_universal.sh",
      "args": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "options": {
        "shell": {
          "executable": "/usr/bin/osascript",
          "args": [
