    {
      "label": "Run ShellSpec Tests (iTerm2)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/run_tests.sh",
      "args": ["--format", "documentation"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "options": {
        "shell": {
          "executable": "/usr/bin/osascript",
          "args": [
            "-e",
            "tell application \"iTerm2\"\n  tell current window\n    create tab with default profile\n    tell current session of current tab\n      write text \"cd '${workspaceFolder}' && ./scripts/run_tests.sh --format documentation\"\n    end tell\n  end tell\nend tell"
          ]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Launch PWA Services (iTerm2)",
      "type": "shell",
      "command": "${workspaceFolder}/web/scripts/launch-all-pwa-services.sh",
      "args": [],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "options": {
        "shell": {
          "executable": "/usr/bin/osascript",
          "args": [
            "-e",
            "tell application \"iTerm2\"\n  tell current window\n    create tab with default profile\n    tell current session of current tab\n      write text \"cd '${workspaceFolder}' && ./web/scripts/launch-all-pwa-services.sh\"\n    end tell\n  end tell\nend tell"
          ]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Build Intel Decimal Library",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "${workspaceFolder}/native/third_party/IntelRDFPMathLib20U2/LIBRARY",
        "-B",
        "${workspaceFolder}/native/third_party/IntelRDFPMathLib20U2/LIBRARY/build",
        "-DCMAKE_BUILD_TYPE=Release"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
