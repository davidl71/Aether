{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "macos-universal-debug"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "CMake: Build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "macos-universal-debug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": "CMake: Configure (Debug)",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "CMake: Build (iTerm2)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "macos-universal-debug"
      ],
      "group": "build",
      "dependsOn": "CMake: Configure (Debug)",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "echo": true,
        "focus": false,
        "revealProblems": "onProblem"
      },
      "options": {
        "shell": {
          "executable": "/usr/bin/osascript",
          "args": [
            "-e",
            "tell application \"iTerm2\"\n  tell current window\n    create tab with default profile\n    tell current session of current tab\n      write text \"cd '${workspaceFolder}' && cmake --build --preset macos-universal-debug\"\n    end tell\n  end tell\nend tell"
          ]
        }
      },
      "problemMatcher": [
        "$gcc"
      ],
      "runOptions": {
        "instanceLimit": 1
      }
    },
    {
      "label": "CMake: Build (Release)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "macos-universal-release"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "CMake: Clean",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "macos-universal-debug",
        "--target",
        "clean"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "ctest",
      "args": [
        "--preset",
        "macos-universal-debug",
        "--output-on-failure"
      ],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "dependsOn": "CMake: Build",
      "problemMatcher": []
    },
    {
      "label": "Run Tests (iTerm2)",
      "type": "shell",
      "command": "ctest",
      "args": [
        "--preset",
        "macos-universal-debug",
        "--output-on-failure"
      ],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "dependsOn": "CMake: Build",
      "options": {
        "shell": {
          "executable": "/usr/bin/osascript",
          "args": [
            "-e",
            "tell application \"iTerm2\"\n  tell current window\n    create tab with default profile\n    tell current session of current tab\n      write text \"cd '${workspaceFolder}' && ctest --preset macos-universal-debug --output-on-failure\"\n    end tell\n  end tell\nend tell"
          ]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Setup Worktree",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/setup_worktree.sh",
      "args": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
