{
  // Workspace-specific user settings (copy to .vscode/settings.json.user)
  // This file is gitignored - customize as needed

  // Auto-run RAM disk startup task (requires "Task Runner" extension or manual setup)
  // Option 1: Use Terminal: Run Active Task command on startup
  // Option 2: Add to shell profile (recommended)
  "task.autoDetect": "on",

  // Keyboard shortcuts (add to keybindings.json):
