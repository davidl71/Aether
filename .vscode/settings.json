{
  // C++ Settings
  // Note: Platform-specific settings should be in .vscode/settings.json.user
  // VS Code will auto-detect from compile_commands.json (generated by CMake)
  // See docs/CROSS_PLATFORM_SETUP.md for platform-specific configurations
  "C_Cpp.default.cppStandard": "c++20",
  // IntelliSense mode will be auto-detected from compile_commands.json
  // Override in settings.json.user if needed:
  // macOS ARM64: "macos-clang-arm64"
  // macOS x86_64: "macos-clang-x64"
  // Windows: "windows-msvc-x64" or "windows-gcc-x64"
  // Linux: "linux-gcc-x64"
  // Compiler path will be auto-detected from compile_commands.json
  // Override in settings.json.user if needed:
  // macOS: "/usr/bin/clang++" or "/opt/homebrew/bin/clang++"
  // Windows: "C:/Program Files/Microsoft Visual Studio/.../cl.exe"
  // Linux: "/usr/bin/g++"
  // Include paths - workspace-relative paths work on all platforms
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/native/include",
    "${workspaceFolder}/native/third_party/tws-api/IBJts/source/cppclient/client"
    // Platform-specific paths should be added in settings.json.user:
    // macOS: "/usr/local/include", "/opt/homebrew/include"
    // Windows: "C:/Program Files/Microsoft Visual Studio/.../include"
    // Linux: "/usr/include", "/usr/local/include"
  ],
  "C_Cpp.default.defines": [
    "_DEBUG",
    "DEBUG"
  ],
  "C_Cpp.default.browse": {
    "path": [
      "${workspaceFolder}/native/include",
      "${workspaceFolder}/native/src",
      "${workspaceFolder}/native/third_party/tws-api/IBJts/source/cppclient/client"
      // Platform-specific paths should be added in settings.json.user
    ],
    "limitSymbolsToIncludedHeaders": false
  },
  "C_Cpp.errorSquiggles": "enabled",
  // Disable clang-tidy on save for performance - use scripts/run_linters.sh instead
  "C_Cpp.codeAnalysis.clangTidy.enabled": false,
  // "C_Cpp.codeAnalysis.clangTidy.checks.enabled": [
  //   "clang-analyzer-*",
  //   "readability-*",
  //   "performance-*",
  //   "modernize-*"
  // ],
  // "C_Cpp.codeAnalysis.clangTidy.checks.disabled": [
  //   "readability-magic-numbers",
  //   "modernize-use-trailing-return-type"
  // ],
  // File Associations
  // Disable language features for unused languages by associating them with plaintext
  "files.associations": {
    // C++ files (actively used)
    "*.h": "cpp",
    "*.hpp": "cpp",
    "*.cpp": "cpp",
    "*.cc": "cpp",
    // CMake files (actively used)
    "CMakeLists.txt": "cmake",
    "*.cmake": "cmake",
    // Java files (only vendor code in third_party, not actively developed)
    "**/third_party/**/*.java": "plaintext",
    // Unused languages - associate with plaintext to disable language features
    "*.go": "plaintext",
    "*.kt": "plaintext",
    "*.kts": "plaintext",
    "*.dart": "plaintext",
    "*.cs": "plaintext",
    "*.php": "plaintext",
    "*.rb": "plaintext",
    "*.scala": "plaintext",
    "*.clj": "plaintext",
    "*.cljs": "plaintext",
    "*.ex": "plaintext",
    "*.exs": "plaintext",
    "*.erl": "plaintext",
    "*.hrl": "plaintext",
    "*.hs": "plaintext",
    "*.ml": "plaintext",
    "*.mli": "plaintext",
    "*.fs": "plaintext",
    "*.fsi": "plaintext",
    "*.fsx": "plaintext",
    "*.R": "plaintext",
    "*.r": "plaintext",
    "*.m": "plaintext",
    "*.lua": "plaintext",
    "*.pl": "plaintext",
    "*.pm": "plaintext",
    "*.vb": "plaintext",
    "*.ps1": "plaintext",
    "*.tf": "plaintext",
    "*.tfvars": "plaintext",
    // Enterprise/Mainframe file types (not used)
    "*.cbl": "plaintext",
    "*.cob": "plaintext",
    "*.cobol": "plaintext",
    "*.rpgle": "plaintext",
    "*.rpg": "plaintext",
    "*.clle": "plaintext",
    "*.jcl": "plaintext",
    "*.pli": "plaintext",
    "*.asm": "plaintext",
    "*.hlasm": "plaintext",
    "*.rexx": "plaintext",
    "*.rex": "plaintext"
  },
  // Editor Settings
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.rulers": [
    100
  ],
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit"
    // Removed "source.organizeImports" - not well-supported for C++ and can slow saves
    // Use manual import organization or clang-format instead
  },
  // "editor.accessibilitySupport": "off",  // Move to User Settings
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  // File Exclusions (from file explorer and AI analysis)
  "files.exclude": {
    "**/build": true,
    "**/build-*": true,
    "**/cmake-build-*": true,
    "**/CMakeFiles": true,
    "**/.cmake": true,
    "**/*.o": true,
    "**/*.so": true,
    "**/*.dylib": true,
    "**/compile_commands.json": false,
    // Third-party vendor code (large, shouldn't be analyzed)
    "native/third_party/tws-api/IBJts/samples": true,
    "native/third_party/tws-api/IBJts/source/pythonclient": true,
    "native/third_party/tws-api/IBJts/source/java": true,
    "native/third_party/IntelRDFPMathLib20U2/EXAMPLES": true,
    "native/third_party/IntelRDFPMathLib20U2/TESTS": true,
    "native/third_party/IntelRDFPMathLib20U2/LIBRARY/src": true,
    "native/third_party/IntelRDFPMathLib20U2/LIBRARY/float128": true,
    "native/third_party/nautilus": true,
    "native/third_party/cache": true,
    // Generated protobuf files
    "**/*.pb.cc": true,
    "**/*.pb.h": true,
    "**/*.pb.go": true,
    // Distribution files
    "dist": true,
    "**/*.tar.gz": true,
    "**/*.sha256": true
  },
  "search.exclude": {
    "**/build": true,
    "**/node_modules": true,
    "**/target": true,
    "**/__pycache__": true,
    "**/.git": true,
    // Third-party vendor code
    "native/third_party/tws-api/IBJts/samples": true,
    "native/third_party/tws-api/IBJts/source/pythonclient": true,
    "native/third_party/tws-api/IBJts/source/java": true,
    "native/third_party/IntelRDFPMathLib20U2/EXAMPLES": true,
    "native/third_party/IntelRDFPMathLib20U2/TESTS": true,
    "native/third_party/IntelRDFPMathLib20U2/LIBRARY/src": true,
    "native/third_party/IntelRDFPMathLib20U2/LIBRARY/float128": true,
    "native/third_party/nautilus": true,
    "native/third_party/cache": true,
    // Generated protobuf files
    "**/*.pb.cc": true,
    "**/*.pb.h": true,
    "**/*.pb.go": true,
    // Distribution files
    "dist": true
  },
  "files.watcherExclude": {
    "**/build/**": true,
    "**/node_modules/**": true,
    "**/target/**": true,
    "**/.git/**": true,
    // Third-party vendor code (reduce file watching overhead)
    "native/third_party/tws-api/**": true,
    "native/third_party/IntelRDFPMathLib20U2/**": true,
    "native/third_party/nautilus/**": true,
    "native/third_party/cache/**": true,
    // Generated files
    "**/*.pb.cc": true,
    "**/*.pb.h": true,
    "**/*.pb.go": true
  },
  // CMake Settings
  // Enhanced CMake Tools extension configuration
  "cmake.configureOnOpen": false,
  "cmake.buildDirectory": "${workspaceFolder}/build",
  "cmake.generator": "Ninja",
  "cmake.configureSettings": {
    "CMAKE_BUILD_TYPE": "Debug",
    "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
  },
  "cmake.sourceDirectory": "${workspaceFolder}/native",
  // CMake Presets support (CMake 3.19+)
  "cmake.useCMakePresets": "always",
  "cmake.presets.default": "macos-x86_64-debug",
  // CMake Tools advanced features
  "cmake.showOptionsMovedNotification": false,
  "cmake.parallelJobs": 0, // 0 = use all available cores
  "cmake.debugConfig": {
    "name": "Debug",
    "type": "cppdbg",
    "request": "launch",
    "program": "${command:cmake.launchTargetPath}",
    "args": [],
    "stopAtEntry": false,
    "cwd": "${workspaceFolder}",
    "environment": [],
    "externalConsole": false,
    "MIMode": "lldb",
    "setupCommands": [
      {
        "description": "Enable pretty-printing for gdb",
        "text": "-enable-pretty-printing",
        "ignoreFailures": true
      }
    ]
  },
  // CMake Tools UI enhancements
  "cmake.statusbar.advanced": {
    "debug": {
      "visibility": "default"
    },
    "launch": {
      "visibility": "default"
    },
    "build": {
      "visibility": "default"
    },
    "configure": {
      "visibility": "default"
    }
  },
  // CMake Tools logging (useful for debugging CMake issues)
  "cmake.loggingLevel": "info", // "trace", "debug", "info", "warning", "error"
  // CMake Tools build target selection
  "cmake.defaultVariants": {
    "buildType": {
      "default": "debug",
      "description": "The build type to use"
    }
  },
  // CMake Tools kit selection (auto-detect)
  "cmake.autoSelectActiveFolder": true,
  // CMake Tools problem matcher for better error parsing
  "cmake.buildToolArgs": [],
  // CMake Tools test integration
  "cmake.testExplorerIntegrationEnabled": true,
  // Python Settings
  // Python interpreter path is platform-specific
  // Override in settings.json.user:
  // macOS: "/usr/local/bin/python3" or "/opt/homebrew/bin/python3"
  // Windows: "C:/Python3xx/python.exe" or use Python from PATH
  // Linux: "/usr/bin/python3"
  // Leave empty to use Python from PATH (recommended for cross-platform)
  "python.defaultInterpreterPath": "",
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.formatting.provider": "black",
  // Python import resolution - add project paths for notebooks and modules
  "python.analysis.extraPaths": [
    "${workspaceFolder}/python",
    "${workspaceFolder}/python/bindings",
    "${workspaceFolder}/python/integration"
  ],
  // Enable import resolution for Jupyter notebooks
  "python.analysis.diagnosticMode": "workspace",
  // Disable flake8 - use trunk's ruff instead (faster, more modern)
  // Use scripts/run_linters.sh for bandit security scanning
  "python.linting.enabled": false,
  // "python.linting.pylintEnabled": false,
  // "python.linting.flake8Enabled": true,
  // Jupyter Notebook Settings
  "jupyter.notebookFileRoot": "${workspaceFolder}",
  // Use same Python interpreter for notebooks
  "jupyter.defaultKernel": "",
  // Enable import resolution in notebook cells
  "jupyter.askForKernelRestart": false,
  // Rust Settings (for agents/backend)
  "rust-analyzer.checkOnSave.command": "clippy",
  "rust-analyzer.cargo.buildScripts.enable": true,
  // TypeScript/JavaScript Settings (for web/)
  "typescript.preferences.importModuleSpecifier": "relative",
  "javascript.preferences.importModuleSpecifier": "relative",
  // Explicit formatter settings to prevent Trunk auto-detection
  // Trunk CLI is used via scripts/run_linters.sh, not as VS Code formatter
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[javascript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },
  "[c]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "[swift]": {
    "editor.defaultFormatter": "sswg.swift-lang"
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  },
  "[shellscript]": {
    "editor.defaultFormatter": null
  },
  "[cmake]": {
    // NOTE: twxs.cmake is NOT recommended - CMake Tools includes built-in Language Services
    // Use CMake Tools built-in formatting or null (no formatter)
    "editor.defaultFormatter": null,
    "editor.formatOnSave": false,
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  // Tabnine Settings (AI Code Completion)
  // Privacy: Enable on-device inference for trading algorithms (if available)
  "tabnine.enableAutoImport": true,
  "tabnine.enableDeepCompletions": true,
  "tabnine.enableInlinePredictions": true,
  // Enable for all project languages
  "tabnine.enableForLanguages": [
    "cpp",
    "c",
    "python",
    "typescript",
    "typescriptreact",
    "javascript",
    "javascriptreact",
    "rust",
    "go"
  ],
  // Privacy settings - keep code local (important for proprietary trading algorithms)
  "tabnine.cloudModelEnabled": false, // Disable cloud model, prefer local if available
  "tabnine.codePrivacyEnabled": true, // Enable code privacy
  // Performance settings
  "tabnine.maxNumResults": 5, // Limit suggestions to reduce resource usage
  "tabnine.debounceMs": 200, // Debounce delay for completions
  // Extension Management
  // Ensure workspace extensions take precedence over global extensions
  "extensions.ignoreRecommendations": true,
  "extensions.showRecommendationsOnlyOnDemand": false,
  // Auto-install workspace recommendations when opening workspace
  "extensions.autoCheckUpdates": true,
  // Disable language-specific features for unused languages
  // This prevents VS Code from loading language servers and extensions for these languages
  "java.configuration.updateBuildConfiguration": "disabled",
  "java.import.gradle.enabled": false,
  "java.import.maven.enabled": false,
  "kotlin.languageServer.enabled": false,
  "dart.enableSdkFormatter": false,
  "dart.enableSnippets": false,
  "php.validate.enable": false,
  "ruby.useLanguageServer": false,
  "scala.server.enabled": false,
  "clojure.enabled": false,
  "elixir.enabled": false,
  "erlang.enabled": false,
  "haskell.enabled": false,
  "ocaml.enabled": false,
  "fsharp.enabled": false,
  "r.enabled": false,
  "matlab.enabled": false,
  "lua.enabled": false,
  "perl.enabled": false,
  "powershell.enable": false,
  // Terminal Settings
  "terminal.integrated.cwd": "${workspaceFolder}",
  // Platform-specific terminal environment variables
  // PYTHONPATH is set for all platforms
  "terminal.integrated.env.osx": {
    "PYTHONPATH": "${workspaceFolder}/python"
  },
  "terminal.integrated.env.windows": {
    "PYTHONPATH": "${workspaceFolder}/python"
  },
  "terminal.integrated.env.linux": {
    "PYTHONPATH": "${workspaceFolder}/python"
  },
  // Git Settings
  // Note: git.ignoreLimitWarning and git.autofetch can be moved to User Settings
  // if they're personal preferences rather than team standards
  "git.ignoreLimitWarning": true,
  "git.autofetch": true,
  // Other Settings
  "files.encoding": "utf8",
  "files.eol": "\n",
  "github.gitProtocol": "ssh",
  "python.testing.pytestArgs": [
    "python"
  ],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true,
  "jupyter.interactiveWindow.creationMode": "perFile",
  "cursorpyright.analysis.autoImportCompletions": true,
  "cursorpyright.analysis.diagnosticMode": "workspace",
  "cursorpyright.analysis.extraPaths": [
    "${workspaceFolder}/python",
    "${workspaceFolder}/python/bindings",
    "${workspaceFolder}/python/integration"
  ],
  "cursorpyright.analysis.typeCheckingMode": "basic",
  // ==========================================
  // Personal Preferences - Move to User Settings
  // ==========================================
  // These settings are personal preferences and should be moved to User Settings
  // See docs/USER_VS_WORKSPACE_SETTINGS.md for details
  //
  // Move these to User Settings:
  // - "audioCues.enabled": "off"
  // - "workbench.settings.enableNaturalLanguageSearch": false
  // - "workbench.colorCustomizations": { ... }
  // - "accessibility.signals.terminalBell": { "sound": "off" }
  // - "terminal.integrated.enableVisualBell": false
  // - "editor.accessibilitySupport": "off"
  //
  // Or create .vscode/settings.json.user (gitignored) for project-specific overrides
  // Disable cursorpyright - redundant with Pylance (python.analysis.typeCheckingMode above)
  // "cursorpyright.analysis.autoImportCompletions": true,
  // "cursorpyright.analysis.typeCheckingMode": "basic"
}
